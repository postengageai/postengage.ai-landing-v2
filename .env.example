# PostEngage.ai Landing — required environment variables
# Copy this file to .env.local and fill in the values for your environment.
# Never commit .env.local to version control.

# ── API ─────────────────────────────────────────────────────────────────────
# Base URL of the gatekeeper backend API (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Analytics (optional) ────────────────────────────────────────────────────
# PostHog project API key — leave blank to disable analytics in development
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Google Analytics 4 — Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Tag Manager — Container ID (e.g. GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# Microsoft Clarity — Project ID
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Meta (Facebook) Pixel — Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=926633326764718
